{
  "name": "@dms/infrastructure",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "cdk": "cdk",
    "synth": "cdk synth",
    "deploy:staging": "cdk deploy --all -c environment=staging --require-approval never",
    "deploy:prod": "cdk deploy --all -c environment=production --require-approval broadening",
    "diff:staging": "cdk diff --all -c environment=staging",
    "diff:prod": "cdk diff --all -c environment=production",
    "destroy:staging": "cdk destroy --all -c environment=staging --force",
    "bootstrap": "cdk bootstrap",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.244.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.15",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "aws-cdk": "^2.1114.0",
    "eslint": "^9.39.4",
    "source-map-support": "^0.5.21",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
