# DMS API — Dev Environment Template
# Copy to .env and fill in actual values

# Database (shared-postgres on VPS)
DATABASE_URL=postgresql://dms_dev:CHANGE_ME@shared-postgres:5432/dms_dev?schema=public

# Redis (shared-redis on VPS)
REDIS_URL=redis://:CHANGE_ME@shared-redis:6379/1

# Application
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=CHANGE_ME
REFRESH_TOKEN_SECRET=CHANGE_ME

# Storage (MinIO or S3)
S3_ENDPOINT=http://minio:9000
S3_BUCKET=dms-documents
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# AI Services
OPENAI_API_KEY=

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
